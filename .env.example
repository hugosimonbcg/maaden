# Vite (client) — prefix with VITE_ only for non-secrets exposed to the browser.
# VITE_PUBLIC_APP_NAME=Maaden Benchmark

# Vercel Edge Middleware (Basic Auth) — used on deploy / `vercel dev` only, not `npm run dev`.
# Set both to require a browser login; omit either to leave the site open.
# BASIC_AUTH_USER=
# BASIC_AUTH_PASS=
